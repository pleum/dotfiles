# Config generated by Ghostty Config

# Font
# font-family = "Google Sans Code"
font-family = "JetBrainsMono Nerd Font"
font-style = Regular
font-size = 14
font-feature = -liga,-calt,-dlig
unfocused-split-opacity = 0.55

# Window
window-theme = ghostty
window-padding-balance = true
window-padding-x = 14
window-padding-y = 14
confirm-close-surface=false
resize-overlay = never
gtk-toolbar-style = flat

theme = catppuccin-mocha.conf
background = #000000
background-opacity = 0.88
background-blur-radius = 25

shell-integration = fish
macos-option-as-alt = left

# Cursor styling
cursor-style = "block"
cursor-style-blink = false

# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

# Keys
# Ascii device control codes: https://www3.rocketsoftware.com/bluezone/help/v42/en/bzadmin/APPENDIX_C/ASCII_Character_Set.htm
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = super+enter=unbind
keybind = alt+backspace=text:\x1b\x7f


