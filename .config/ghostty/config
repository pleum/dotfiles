# Config generated by Ghostty Config

font-feature = -calt
font-feature = -liga
font-feature = -dlig
adjust-underline-position = 2
adjust-cell-height = -1

# macos-titlebar-style = hidden
window-padding-y = 2,0
window-padding-x = 2
window-padding-balance = true

background-opacity = 0.90
background-blur = true

macos-option-as-alt = left
# macos-window-shadow = false
macos-icon = retro
macos-icon-frame = beige

shell-integration = fish

#window-padding-y = 4
# theme = UltraDark

theme = catppuccin-mocha.conf
background = #000000
selection-background = #222222
selection-foreground = #cccccc
cursor-color = #fefefe
cursor-text = #000000
font-size = 14

# Keys
# Ascii device control codes: https://www3.rocketsoftware.com/bluezone/help/v42/en/bzadmin/APPENDIX_C/ASCII_Character_Set.htm
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = super+enter=unbind

macos-option-as-alt = left
